package com.example.module3_2edgar;

import android.util.Log;

import java.security.MessageDigest;
import java.security.NoSuchAlgorithmException;
import java.security.SecureRandom;
import java.util.Base64;

/*
Enhancement 2 Intro (Algorithms and Data Structures):
    This is responsible for all cryptographic password operations.
    It is intentionally static, so it has no dependencies and can be
    used from any layer of the application.

    It generates a cryptographically random salt for each new user.
    It hashes a password combined with a salt using SHA-256.
    Automatic verification of a login attempt by re-hashing and comparing
 */
public class PasswordUtils {

    // Tag used for Android log messages from this class
    private static final String LOG_TAG = "PasswordUtils";

    // Length of the generated salt in bytes.
    private static final int SALT_LENGTH_BYTES = 16;

    // SHA-256 produces a 256-bit digest and is available on all Android versions.
    private static final String HASH_ALGORITHM = "SHA-256";

    private PasswordUtils() {}

    /*
    Generates a cryptographically random salt value encoded as a Base64 string.
    A new salt must be generated for every user at registration time.
    The salt is stored alongside the password hash in the database.
    */
    public static String generateSalt() {
        SecureRandom random = new SecureRandom();
        byte[] saltBytes = new byte[SALT_LENGTH_BYTES];
        random.nextBytes(saltBytes);
        return Base64.getEncoder().encodeToString(saltBytes);
    }

    // Hashes a password combined with a salt using SHA-256.
    public static String hashPassword(String password, String salt) {
        try {
            MessageDigest digest = MessageDigest.getInstance(HASH_ALGORITHM);
            // Combine salt and password into a single input string
            String saltedPassword = salt + password;
            byte[] hashBytes = digest.digest(saltedPassword.getBytes());
            return Base64.getEncoder().encodeToString(hashBytes);
        } catch (NoSuchAlgorithmException e) {
            Log.e(LOG_TAG, "SHA-256 algorithm not available: " + e.getMessage(), e);
            return null;
        }
    }

    /*
    Verifies a login attempt by re-hashing the provided password with the
    stored salt and comparing the result to the stored hash.

    Returns true if the computed hash matches the stored hash, and
    false if they differ or if hashing fails.
     */
    public static boolean verifyPassword(String inputPassword, String storedSalt, String storedHash) {
        String computedHash = hashPassword(inputPassword, storedSalt);
        if (computedHash == null) {
            return false;
        }
        // Use equals() for string comparison. Both values are Base64-encoded
        return computedHash.equals(storedHash);
    }
}
